# IMOS Receiver Server - Configuration
# Edit this file, then re-run install.ps1 (no params needed)
#
# Re-install command:
#   powershell -ExecutionPolicy Bypass -File install.ps1

PORT=3500

# imos cron consumer path
IMOS_INBOX=C:\imos_inbox


# where install.psl located 
INSTALL_DIR=C:\imos-receiver

# Shared secret — must match IMOS_API_TOKEN in the sender's .env
API_TOKEN=


# Comma-separated IPs allowed to POST (leave empty to allow all)
# Set this to your sender server IP (e.g. 192.168.30.92)
ALLOWED_IPS=
